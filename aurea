<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Aurea Pad van Licht — Anja Bierman | Yoga, Reiki & Therapie in Hoogwoud</title>
<link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Nunito:wght@300;400;600;700&family=Playfair+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --green:      #6DBF4A;
  --green-dark: #4E9933;
  --green-light:#8DD66A;
  --pink:       #E8609A;
  --pink-light: #F0A0C4;
  --pink-pale:  #FCE8F2;
  --white:      #FFFFFF;
  --offwhite:   #FAFFF7;
  --text:       #2D3A1F;
  --text-light: #4A5E35;
  --shadow:     rgba(0,0,0,0.12);
}

html { scroll-behavior: smooth; }

body {
  font-family: 'Nunito', sans-serif;
  background: var(--green);
  color: var(--text);
  font-weight: 400;
  line-height: 1.7;
  overflow-x: hidden;
}

/* ═══ PAGES ═══ */
.page { display: none; }
.page.active { display: block; }

/* ═══ NAV ═══ */
nav {
  background: var(--pink);
  padding: 0;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 3px 12px rgba(0,0,0,0.18);
}
.nav-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
}
.nav-inner a {
  display: block;
  padding: 16px 36px;
  font-family: 'Nunito', sans-serif;
  font-weight: 700;
  font-size: 15px;
  letter-spacing: 0.04em;
  color: var(--white);
  text-decoration: none;
  cursor: pointer;
  position: relative;
  transition: background 0.25s, color 0.25s;
  white-space: nowrap;
}
.nav-inner a::after {
  content: '';
  position: absolute;
  bottom: 0; left: 50%; right: 50%;
  height: 3px;
  background: var(--white);
  border-radius: 3px 3px 0 0;
  transition: left 0.3s, right 0.3s;
}
.nav-inner a:hover, .nav-inner a.active {
  background: rgba(255,255,255,0.15);
}
.nav-inner a:hover::after, .nav-inner a.active::after {
  left: 12px; right: 12px;
}

/* ═══ HEADER ═══ */
.site-header {
  background: var(--green);
  padding: 36px 40px 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  max-width: 1100px;
  margin: 0 auto;
  gap: 32px;
}
.header-logo-img {
  width: 130px; height: 130px;
  border-radius: 16px;
  object-fit: cover;
  box-shadow: 0 6px 24px rgba(0,0,0,0.18);
  border: 4px solid var(--white);
  flex-shrink: 0;
  transition: transform 0.3s;
}
.header-logo-img:hover { transform: scale(1.04) rotate(2deg); }
.header-center {
  flex: 1;
  text-align: center;
}
.header-title {
  font-family: 'Pacifico', cursive;
  font-size: clamp(52px, 7vw, 88px);
  color: var(--white);
  text-shadow: 3px 3px 0 rgba(0,0,0,0.15), 0 0 40px rgba(255,255,255,0.3);
  line-height: 1;
  margin-bottom: 6px;
  letter-spacing: 0.02em;
}
.header-subtitle {
  font-size: 14px;
  color: rgba(255,255,255,0.85);
  font-weight: 300;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}
.header-anja-img {
  width: 130px; height: 130px;
  border-radius: 50%;
  object-fit: cover;
  object-position: center top;
  box-shadow: 0 6px 24px rgba(0,0,0,0.18);
  border: 4px solid var(--white);
  flex-shrink: 0;
  transition: transform 0.3s;
}
.header-anja-img:hover { transform: scale(1.04); }

/* ═══ HOME PAGE ═══ */
.home-welcome {
  background: var(--green);
  text-align: center;
  padding: 32px 40px 20px;
}
.welcome-box {
  display: inline-block;
  background: rgba(255,255,255,0.22);
  backdrop-filter: blur(6px);
  border: 2px solid rgba(255,255,255,0.4);
  border-radius: 20px;
  padding: 28px 48px;
  max-width: 640px;
}
.welcome-box h2 {
  font-family: 'Playfair Display', serif;
  font-size: 26px;
  color: var(--white);
  margin-bottom: 12px;
  font-weight: 400;
}
.welcome-box .tagline {
  font-size: 15px;
  color: rgba(255,255,255,0.92);
  line-height: 1.6;
  font-weight: 300;
}
.welcome-box .tagline strong {
  color: var(--white);
  font-weight: 700;
}

/* ═══ IMAGE PANELS (home) ═══ */
.panels-section {
  padding: 28px 20px 36px;
  background: var(--green);
}
.panels-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  max-width: 1100px;
  margin: 0 auto;
}
.panel-card {
  position: relative;
  border-radius: 20px;
  overflow: hidden;
  cursor: pointer;
  box-shadow: 0 8px 28px rgba(0,0,0,0.22);
  aspect-ratio: 4/3;
  transition: transform 0.3s, box-shadow 0.3s;
  border: 3px solid rgba(255,255,255,0.35);
}
.panel-card:hover {
  transform: translateY(-6px) scale(1.01);
  box-shadow: 0 16px 40px rgba(0,0,0,0.3);
}
.panel-card img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.5s ease;
}
.panel-card:hover img { transform: scale(1.06); }
.panel-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.1) 55%, transparent 100%);
}
.panel-label {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 20px 20px 18px;
  text-align: center;
}
.panel-label span {
  display: inline-block;
  background: var(--pink);
  color: var(--white);
  font-family: 'Nunito', sans-serif;
  font-weight: 700;
  font-size: 16px;
  padding: 8px 28px;
  border-radius: 30px;
  box-shadow: 0 3px 12px rgba(0,0,0,0.2);
  letter-spacing: 0.04em;
  transition: background 0.3s, transform 0.2s;
}
.panel-card:hover .panel-label span {
  background: var(--green-dark);
  transform: scale(1.05);
}

/* ═══ INNER PAGE HERO ═══ */
.inner-hero {
  position: relative;
  height: 300px;
  overflow: hidden;
}
.inner-hero img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
}
.inner-hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(77,153,51,0.75), rgba(232,96,154,0.5));
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 0 60px;
}
.inner-hero-title {
  font-family: 'Pacifico', cursive;
  font-size: clamp(36px, 5vw, 58px);
  color: var(--white);
  text-shadow: 2px 2px 8px rgba(0,0,0,0.25);
}

/* ═══ CONTENT SECTIONS ═══ */
.content-section {
  background: var(--green);
  padding: 48px 20px 56px;
}
.content-inner {
  max-width: 1100px;
  margin: 0 auto;
}
.content-card {
  background: rgba(255,255,255,0.92);
  border-radius: 24px;
  padding: 48px 56px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.10);
  border: 2px solid rgba(255,255,255,0.7);
}
.content-card h2 {
  font-family: 'Playfair Display', serif;
  font-size: 32px;
  color: var(--green-dark);
  margin-bottom: 20px;
  font-weight: 400;
  font-style: italic;
}
.content-card p {
  font-size: 16px;
  color: var(--text);
  line-height: 1.8;
  margin-bottom: 16px;
}
.content-card p:last-child { margin-bottom: 0; }

/* ═══ TWO COL LAYOUT ═══ */
.two-col { display: grid; grid-template-columns: 1.3fr 1fr; gap: 48px; align-items: start; }
.two-col-reverse { grid-template-columns: 1fr 1.3fr; }

/* ═══ ROOSTER ═══ */
.rooster-card {
  background: var(--pink);
  border-radius: 20px;
  padding: 32px 36px;
  color: var(--white);
  box-shadow: 0 6px 24px rgba(232,96,154,0.3);
}
.rooster-card h3 {
  font-family: 'Pacifico', cursive;
  font-size: 22px;
  margin-bottom: 20px;
  letter-spacing: 0.02em;
}
.rooster-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 11px 0;
  border-bottom: 1px solid rgba(255,255,255,0.22);
  font-size: 15px;
}
.rooster-row:last-of-type { border: none; }
.rooster-time {
  background: rgba(255,255,255,0.22);
  border-radius: 20px;
  padding: 4px 14px;
  font-weight: 700;
  font-size: 14px;
  letter-spacing: 0.05em;
}
.rooster-note {
  margin-top: 16px;
  padding-top: 14px;
  border-top: 1px solid rgba(255,255,255,0.2);
  font-size: 13px;
  opacity: 0.8;
  text-align: center;
}

/* ═══ FEATURES LIST ═══ */
.feat-list {
  background: var(--green-dark);
  border-radius: 20px;
  padding: 28px 32px;
  color: var(--white);
}
.feat-list h3 {
  font-family: 'Pacifico', cursive;
  font-size: 18px;
  margin-bottom: 16px;
  letter-spacing: 0.02em;
}
.feat-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 9px 0;
  border-bottom: 1px solid rgba(255,255,255,0.12);
  font-size: 15px;
  line-height: 1.5;
}
.feat-item:last-child { border: none; }
.feat-dot { color: var(--pink-light); flex-shrink: 0; margin-top: 2px; font-size: 16px; }

/* ═══ THERAPY CARDS ═══ */
.therapy-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin: 32px 0;
}
.therapy-card {
  background: var(--green-dark);
  border-radius: 20px;
  padding: 32px 28px;
  color: var(--white);
  box-shadow: 0 4px 16px rgba(0,0,0,0.10);
  transition: transform 0.3s, box-shadow 0.3s;
  border-top: 4px solid var(--pink);
}
.therapy-card:hover { transform: translateY(-4px); box-shadow: 0 10px 28px rgba(0,0,0,0.15); }
.therapy-icon { font-size: 32px; margin-bottom: 14px; }
.therapy-card h3 { font-family: 'Playfair Display', serif; font-size: 20px; color: var(--white); margin-bottom: 12px; font-style: italic; }
.therapy-card p { font-size: 14px; line-height: 1.7; opacity: 0.88; }

/* ═══ KLACHTEN ═══ */
.klachten-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  margin-top: 28px;
  border-radius: 16px;
  overflow: hidden;
  border: 2px solid var(--green-light);
}
.klacht-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 14px 20px;
  background: rgba(255,255,255,0.88);
  border-bottom: 1px solid var(--green-light);
  border-right: 1px solid var(--green-light);
  font-size: 15px;
  color: var(--text);
  line-height: 1.45;
  transition: background 0.2s;
}
.klacht-item:hover { background: var(--pink-pale); }
.klacht-item:nth-child(2n) { border-right: none; }
.klacht-item:nth-last-child(-n+2) { border-bottom: none; }
.klacht-gem { color: var(--pink); flex-shrink: 0; font-size: 14px; margin-top: 2px; }

/* ═══ HECHTING PAGE ═══ */
.gevolgen-list { list-style: none; margin: 20px 0; }
.gevolgen-list li {
  display: flex;
  gap: 12px;
  padding: 13px 0;
  border-bottom: 1px dashed rgba(78,153,51,0.25);
  font-size: 15.5px;
  color: var(--text);
  line-height: 1.55;
}
.gevolgen-list li:last-child { border: none; }
.gevolgen-list li::before { content: "✿"; color: var(--pink); flex-shrink: 0; }

/* ═══ METHODEN ═══ */
.methoden-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 20px; }
.methode-item {
  background: var(--pink-pale);
  border: 2px solid var(--pink-light);
  border-radius: 14px;
  padding: 14px 20px;
  font-size: 15px;
  color: var(--text);
  display: flex;
  align-items: center;
  gap: 10px;
  font-weight: 600;
}
.methode-item .mi-icon { font-size: 18px; }

/* ═══ OVER MIJ STRIP ═══ */
.about-strip {
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(4px);
  border: 2px solid rgba(255,255,255,0.3);
  border-radius: 20px;
  padding: 28px 36px;
  margin-bottom: 32px;
  display: flex;
  align-items: center;
  gap: 28px;
}
.about-strip img {
  width: 100px; height: 100px;
  border-radius: 50%;
  object-fit: cover;
  object-position: center top;
  border: 3px solid var(--white);
  box-shadow: 0 4px 14px rgba(0,0,0,0.15);
  flex-shrink: 0;
}
.about-strip-text { color: var(--white); }
.about-strip-text h3 { font-family: 'Pacifico', cursive; font-size: 20px; margin-bottom: 6px; }
.about-strip-text p { font-size: 14px; opacity: 0.9; line-height: 1.6; }

/* ═══ QUOTE ═══ */
.quote-box {
  background: var(--pink);
  border-radius: 20px;
  padding: 28px 36px;
  margin: 28px 0;
  color: var(--white);
  text-align: center;
  box-shadow: 0 4px 20px rgba(232,96,154,0.3);
}
.quote-box p {
  font-family: 'Playfair Display', serif;
  font-size: 18px;
  font-style: italic;
  line-height: 1.6;
  color: var(--white);
  margin: 0;
}
.quote-box cite {
  display: block;
  margin-top: 10px;
  font-size: 12px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  opacity: 0.85;
  font-style: normal;
  font-weight: 700;
}

/* ═══ CONTACT ═══ */
.contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 36px; }
.contact-info {
  background: var(--green-dark);
  border-radius: 20px;
  padding: 40px 36px;
  color: var(--white);
}
.contact-info h2 { font-family: 'Pacifico', cursive; font-size: 24px; margin-bottom: 24px; }
.contact-detail { margin-bottom: 20px; }
.contact-label { font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--pink-light); margin-bottom: 4px; font-weight: 700; }
.contact-val { font-size: 16px; line-height: 1.5; }
.contact-val a { color: var(--white); text-decoration: none; border-bottom: 1px dotted rgba(255,255,255,0.4); transition: border-color 0.3s; }
.contact-val a:hover { border-color: var(--white); }
.contact-services {
  margin-top: 24px;
  padding-top: 20px;
  border-top: 1px solid rgba(255,255,255,0.15);
  font-size: 14px;
  opacity: 0.8;
  line-height: 2.0;
}
.contact-form-card {
  background: rgba(255,255,255,0.92);
  border-radius: 20px;
  padding: 40px 36px;
  border: 2px solid rgba(255,255,255,0.7);
}
.contact-form-card h2 { font-family: 'Pacifico', cursive; font-size: 24px; color: var(--green-dark); margin-bottom: 6px; }
.contact-form-card .form-sub { font-size: 14px; color: var(--text-light); margin-bottom: 24px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.form-grp { margin-bottom: 16px; }
.form-grp label { display: block; font-size: 11px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-light); margin-bottom: 6px; }
.form-grp input, .form-grp textarea {
  width: 100%;
  padding: 12px 16px;
  background: #fff;
  border: 2px solid #dce8d5;
  border-radius: 10px;
  color: var(--text);
  font-family: 'Nunito', sans-serif;
  font-size: 15px;
  font-weight: 400;
  outline: none;
  transition: border-color 0.3s, box-shadow 0.3s;
  resize: none;
}
.form-grp input:focus, .form-grp textarea:focus {
  border-color: var(--pink);
  box-shadow: 0 0 0 3px rgba(232,96,154,0.12);
}
.form-grp textarea { min-height: 110px; }
.form-btn {
  width: 100%;
  padding: 15px;
  background: var(--pink);
  color: var(--white);
  border: none;
  border-radius: 10px;
  font-family: 'Nunito', sans-serif;
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.3s, transform 0.2s;
  margin-top: 4px;
}
.form-btn:hover { background: var(--green-dark); transform: translateY(-1px); }

/* ═══ FOOTER ═══ */
footer {
  background: var(--green-dark);
  padding: 40px 40px 24px;
  color: rgba(255,255,255,0.7);
  text-align: center;
}
.footer-inner { max-width: 1100px; margin: 0 auto; }
.footer-top {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 40px;
  text-align: left;
  padding-bottom: 28px;
  border-bottom: 1px solid rgba(255,255,255,0.12);
  margin-bottom: 20px;
}
.footer-logo { font-family: 'Pacifico', cursive; font-size: 22px; color: var(--white); margin-bottom: 8px; display: flex; align-items: center; gap: 10px; }
.footer-tagline { font-size: 13px; line-height: 1.65; }
.footer-col-head { font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--pink-light); font-weight: 700; margin-bottom: 12px; }
.footer-links { list-style: none; }
.footer-links li { margin-bottom: 8px; }
.footer-links li a { color: rgba(255,255,255,0.65); text-decoration: none; font-size: 14px; cursor: pointer; transition: color 0.3s; }
.footer-links li a:hover { color: var(--white); }
.footer-contact-info { font-size: 13px; line-height: 2; }
.footer-contact-info a { color: rgba(255,255,255,0.65); text-decoration: none; transition: color 0.3s; }
.footer-contact-info a:hover { color: var(--white); }
.footer-bottom { font-size: 12px; opacity: 0.45; }

/* ═══ DECORATIVE ═══ */
.flower-divider { text-align: center; margin: 20px 0; font-size: 22px; color: rgba(255,255,255,0.4); letter-spacing: 10px; }
.section-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--pink);
  color: var(--white);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  padding: 6px 18px;
  border-radius: 30px;
  margin-bottom: 16px;
}
.phone-bubble {
  background: var(--white);
  border: 3px solid var(--green-light);
  border-radius: 20px;
  padding: 20px 28px;
  text-align: center;
  margin-top: 16px;
}
.phone-bubble .pb-label { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-light); margin-bottom: 4px; }
.phone-bubble .pb-num { font-family: 'Pacifico', cursive; font-size: 26px; color: var(--pink); }

/* ANIMATIONS */
@keyframes fadeUp { from { opacity:0; transform:translateY(24px); } to { opacity:1; transform:translateY(0); } }
.fu { animation: fadeUp 0.7s ease both; }
.fu-1 { animation-delay: 0.05s; }
.fu-2 { animation-delay: 0.18s; }
.fu-3 { animation-delay: 0.3s; }
.fu-4 { animation-delay: 0.44s; }

/* RESPONSIVE */
@media (max-width: 860px) {
  .site-header { flex-direction: column; text-align: center; padding: 24px 20px 16px; }
  .nav-inner { flex-wrap: wrap; justify-content: center; }
  .nav-inner a { padding: 12px 20px; font-size: 13px; }
  .panels-grid { grid-template-columns: 1fr; max-width: 420px; }
  .two-col, .two-col-reverse, .contact-grid, .therapy-grid, .klachten-list, .methoden-grid { grid-template-columns: 1fr; }
  .content-card { padding: 32px 24px; }
  .footer-top { grid-template-columns: 1fr; gap: 24px; }
  .about-strip { flex-direction: column; text-align: center; }
}
</style>
</head>
